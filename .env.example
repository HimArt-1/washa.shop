# ─── نسخ هذا الملف إلى .env.local وملء القيم. لا ترفع .env.local إلى Git. ───

# Clerk (المصادقة)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxx
CLERK_SECRET_KEY=sk_test_xxxx
# Clerk Webhook — مزامنة المستخدمين مع Supabase (من لوحة Clerk → Webhooks)
# CLERK_WEBHOOK_SIGNING_SECRET=whsec_xxxx

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxx

# توليد الصور (أداة التصميم) — خيارات المزوّد: nanobanana (Gemini 3 Flash), replicate (Flux), gemini (Imagen 3)
# اختياري: تحديد المزوّد. الافتراضي nanobanana إذا توفر GEMINI_API_KEY
IMAGE_PROVIDER=nanobanana

# WASHA AI (DTF) — اختياري. إن لُم يُضبط: يُستخدم IMAGE_PROVIDER وإن كان فارغاً يُلجأ لـ genai
# WASHA_DTF_IMAGE_PROVIDER=genai
# WASHA_DTF_IMAGE_PROVIDER=replicate
# WASHA_DTF_IMAGE_PROVIDER=nanobanana
# WASHA_DTF_IMAGE_PROVIDER=gemini
# نموذج توليد الصور داخل DTF (مسار @google/genai) — اختياري:
# WASHA_DTF_GENAI_MODEL=gemini-3.1-flash-image-preview
# للرجوع للجيل السابق: WASHA_DTF_GENAI_MODEL=gemini-2.5-flash-image
# إن استُخدمت واجهة :predict (nanobanana في أداة التصميم) فقط:
# NANO_BANANA_PREDICT_MODEL=imagen-4.0-ultra-generate-001

# Gemini (Nano Banana / Imagen)
GEMINI_API_KEY=AIxxxxxxxxxxxxxxxxxxxxxxxxx

# Replicate (Flux)
REPLICATE_API_TOKEN=r8_xxxx

# Resend (البريد الإلكتروني)
# RESEND_API_KEY=re_xxxx
# EMAIL_FROM=وشّى <noreply@yourdomain.com>

# إشعارات الأدمن بالبريد (طلبات، انضمام)
# ADMIN_EMAIL=admin@yourdomain.com

# Web Push (إشعارات المتصفح). توليد المفاتيح: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=xxxx
# VAPID_PRIVATE_KEY=xxxx
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=xxxx  (نفس القيمة العامة)

# Stripe (الدفع الإلكتروني — Visa, Mada, Apple Pay)
# STRIPE_SECRET_KEY=sk_test_xxxx
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxx

# Seed (للإنتاج فقط — حماية مسار /api/seed)
# SEED_SECRET=your-random-secret-here

# عنوان الموقع (للروابط في البريد، Stripe، إلخ)
# NEXT_PUBLIC_APP_URL=https://yourdomain.com
